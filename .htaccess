# ------------------------------------------------------------------------------
# | Canonical Redirects (HTTPS & WWW)
# ------------------------------------------------------------------------------
RewriteEngine On
RewriteCond %{HTTP_HOST} ^dentplant\.gr [NC]
RewriteRule ^(.*)$ https://www.dentplant.gr/$1 [L,R=301]
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://www.dentplant.gr/$1 [L,R=301]

# ------------------------------------------------------------------------------
# | Legacy Article Redirects (moved to /article/ subfolder)
# ------------------------------------------------------------------------------
Redirect 301 /article-candidate.html https://www.dentplant.gr/article/article-candidate.html
Redirect 301 /article-bone-graft.html https://www.dentplant.gr/article/article-bone-graft.html
Redirect 301 /article-timeline.html https://www.dentplant.gr/article/article-timeline.html
Redirect 301 /article-cost.html https://www.dentplant.gr/article/article-cost.html
Redirect 301 /article-comparison.html https://www.dentplant.gr/article/article-comparison.html
Redirect 301 /article-sedation.html https://www.dentplant.gr/article/article-sedation.html

# ------------------------------------------------------------------------------
# | URL Cleanup (Remove .html extension)
# ------------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# ------------------------------------------------------------------------------
# | Performance (Gzip Compression)
# ------------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ------------------------------------------------------------------------------
# | Browser Caching
# ------------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# ------------------------------------------------------------------------------
# | Security
# ------------------------------------------------------------------------------
Options -Indexes
